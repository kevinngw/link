{
  "name": "link",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/build-link-data.mjs",
    "dev": "vite",
    "prebuild": "node scripts/build-link-data.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "build:ios": "VITE_CAPACITOR=true VITE_BASE=/ vite build",
    "cap:sync": "npx cap sync ios",
    "cap:open": "npx cap open ios",
    "ios": "npm run build:ios && npm run cap:sync && npm run cap:open",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:run": "vitest run"
  },
  "devDependencies": {
    "@vitest/ui": "^4.1.0",
    "jsdom": "^29.0.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/geolocation": "^8.1.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "adm-zip": "^0.5.16",
    "csv-parse": "^6.1.0",
    "vite-plugin-pwa": "^1.2.0"
  }
}
