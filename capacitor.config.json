{
  "appId": "io.kevinngw.linkpulse",
  "appName": "LinkPulse",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https"
  },
  "ios": {
    "contentInset": "automatic",
    "backgroundColor": "#08141f"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": false,
      "backgroundColor": "#08141f",
      "showSpinner": false,
      "fadeOutDuration": 300
    }
  }
}
